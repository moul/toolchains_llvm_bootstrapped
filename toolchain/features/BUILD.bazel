cc_feature(
    name = "prefer_pic_for_opt_binaries",
    feature_name = "prefer_pic_for_opt_binaries",
)

# Allow external repositories to get included with -isystem instead of -I.
# in order to silence warnings from external headers.
cc_feature(
    name = "external_include_paths",
    args = ["@rules_cc//cc/toolchains/args/external_include_paths:external_include_paths"],
    feature_name = "external_include_paths",
)

cc_feature(
    name = "copy_dynamic_libraries_to_binary",
    feature_name = "copy_dynamic_libraries_to_binary",
)

cc_feature(
    name = "targets_windows",
    feature_name = "targets_windows",
    implies = [":copy_dynamic_libraries_to_binary"],
)

cc_feature(
    name = "windows_export_all_symbols",
    feature_name = "windows_export_all_symbols",
)

cc_feature(
    name = "no_windows_export_all_symbols",
    feature_name = "no_windows_export_all_symbols",
)

cc_args(
    name = "opt_link_flags",
    actions = [
        "@rules_cc//cc/toolchains/actions:link_actions",
    ],
    args = select({
        "@platforms//os:macos": [
            #TODO: should be on a config that match ld64 specifically
            "-Wl,-dead_strip",
        ],
        "@platforms//os:windows": [],
        "//conditions:default": [
            #TODO: should be somehow done only if the choosen linker supports it
            "-Wl,--gc-sections",
        ],
    }) + select({
        "//config:asan_enabled": [],
        "//config:msan_enabled": [],
        "//config:dfsan_enabled": [],
        "//config:nsan_enabled": [],
        "//config:safestack_enabled": [],
        "//config:rtsan_enabled": [],
        "//config:tysan_enabled": [],
        "//config:tsan_enabled": [],
        "//config:ubsan_enabled": [],
        "//config:cfi_enabled": [],
        "//config:lsan_enabled": [],
        "@platforms//cpu:wasm32": [],
        "@platforms//cpu:wasm64": [],
        "@platforms//os:windows": [],
        "//conditions:default": ["-Wl,--icf=safe"],
    }),
)

cc_args(
    name = "opt_compile_flags",
    actions = [
        "@rules_cc//cc/toolchains/actions:compile_actions",
    ],
    args = [
        # No debug symbols.
        # Maybe we should enable https://gcc.gnu.org/wiki/DebugFission for opt or
        # even generally? However, that can't happen here, as it requires special
        # handling in Bazel.
        "-g0",

        # Conservative choice for -O
        # -O3 can increase binary size and even slow down the resulting binaries.
        # Profile first and / or use FDO if you need better performance than this.
        "-O2",

        # Security hardening on by default.
        # Conservative choice; -D_FORTIFY_SOURCE=2 may be unsafe in some cases.
        "-D_FORTIFY_SOURCE=1",

        # Disable assertions
        "-DNDEBUG",

        # Removal of unused code and data at link time (can this increase binary
        # size in some cases?).
        "-ffunction-sections",
        "-fdata-sections",
    ],
)

# Use a stub feature so we can properly control flag ordering.
cc_feature(
    name = "opt",
    args = [
        ":opt_compile_flags",
        ":opt_link_flags",
    ],
    feature_name = "_underlying_opt",
    requires_any_of = [":opt_stub"],
)

cc_feature(
    name = "opt_stub",
    overrides = "@rules_cc//cc/toolchains/features:opt",
)

cc_args(
    name = "dbg_compile_flags",
    actions = [
        "@rules_cc//cc/toolchains/actions:compile_actions",
    ],
    args = [
        # windows c runtime requires -D_DEBUG if using debug libraries
        "-D_DEBUG",

        # Clang has -Og for compatibility with GCC, but currently it is just equivalent
        # to -O1. Besides potentially impairing debugging, -O1/-Og significantly
        # increases compile times.
        "-O0",

        # Debug symbols.
        "-g",
    ],
)

# Use a stub feature so we can properly control flag ordering.
cc_feature(
    name = "dbg",
    args = [
        ":dbg_compile_flags",
    ],
    feature_name = "_underlying_dbg",
    requires_any_of = [":dbg_stub"],
)

cc_feature(
    name = "dbg_stub",
    overrides = "@rules_cc//cc/toolchains/features:dbg",
)

cc_feature(
    name = "archive_param_file",
    feature_name = "archive_param_file",
)

cc_feature(
    name = "parse_headers_wrapper",
    args = [
        "//toolchain/args:parse_header_args",
    ],
    feature_name = "__parse_headers_wrapper",
    requires_any_of = [":parse_headers"],
)

cc_feature(
    name = "parse_headers",
    feature_name = "parse_headers",
)

cc_args(
    name = "generate_dsym_file_compile_args",
    actions = _DEBUG_INFO_COMPILE_ACTIONS,
    args = ["-g"],
)

cc_args(
    name = "generate_dsym_file_link_args",
    actions = _FINAL_LINK_ACTIONS,
    env = {
        "LLVM_DSYM_PATH": "{dsym_path}",
        "LLVM_LINK_OUTPUT": "{output_execpath}",
    },
    format = {
        "dsym_path": "@rules_cc//cc/toolchains/variables:dsym_path",
        "output_execpath": "@rules_cc//cc/toolchains/variables:output_execpath",
    },
    requires_not_none = "@rules_cc//cc/toolchains/variables:dsym_path",
)

cc_feature(
    name = "generate_dsym_file",
    args = [
        ":generate_dsym_file_compile_args",
        ":generate_dsym_file_link_args",
    ],
    overrides = "@rules_cc//cc/toolchains/features/legacy:generate_dsym_file",
)

cc_args(
    name = "generate_pdb_file_compile_args",
    actions = _DEBUG_INFO_COMPILE_ACTIONS,
    args = ["-gcodeview"],
)

cc_args(
    name = "generate_pdb_file_link_args",
    actions = _FINAL_LINK_ACTIONS,
    args = ["-Wl,--pdb="],
)

cc_feature(
    name = "generate_pdb_file",
    args = [
        ":generate_pdb_file_compile_args",
        ":generate_pdb_file_link_args",
