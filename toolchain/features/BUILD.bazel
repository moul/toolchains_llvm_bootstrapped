    actions = ["@rules_cc//cc/toolchains/actions:link_actions"],
    args = ["-fprofile-instr-generate"] + select({
        "@platforms//os:windows": [
            "-Wl,-u,__llvm_profile_runtime",
            "-Wl,/include:__llvm_profile_runtime",
