copy_file(
    name = "pthread",
    src = ":winpthread",
    out = "libpthread.a",
    visibility = ["//visibility:public"],
)

# An empty library that provides "-lm", which is pervasive in Bazel build files
# but not actually needed for Windows.
stub_library(
    name = "m",
    visibility = ["//visibility:public"],
)

# TODO(zbarsky): Hack for now until we have real libstdc++ support...
stub_library(
    name = "stdc++",
)

copy_to_directory(
    name = "mingw_crt_library_search_directory",
    srcs = [
        ":m",
        ":mingw32",
        ":mingwex",
        ":moldname",
        ":pthread",
        ":stdc++",
        ":uuid",
        ":winpthread",
    ] + select({
        "//constraints/windows/crt:msvcrt": [
            ":msvcrt_common",
            ":msvcrt_extra",
        ],
        "//constraints/windows/crt:ucrt": [
            ":ucrt",
            ":ucrtbase",
            ":ucrtbased",
        ],
    }),
    # cc_library archives are emitted below target-specific directories such
    # as mingw32_/libmingw32.a. Make those directories copy roots so the CRT
    # search directory contains the upstream archive basenames.
    root_paths = [
        ".",
        "runtimes/mingw/mingw32_",
        "runtimes/mingw/mingwex_",
        "runtimes/mingw/moldname_",
        "runtimes/mingw/msvcrt_common_",
        "runtimes/mingw/msvcrt_extra_",
        "runtimes/mingw/uuid_",
        "runtimes/mingw/winpthread_",
        "windows",
    ],
    visibility = ["//visibility:public"],
)

copy_to_directory(
    name = "mingw_import_libraries_directory",
    srcs = [
        ":libkernel32.a",
        ":libsynchronization.a",
        ":libws2_32.a",
        "@mingw//:mingw_import_libraries_common",
    ] + select({
        "@platforms//cpu:x86_64": ["@mingw//:mingw_import_libraries_x86_64"],
        # Aarch64 are fully templatized in .def.in files, x86_64 have not been merged yet.
        "@platforms//cpu:aarch64": [],
    }),
    include_external_repositories = ["**"],
    root_paths = [
        ".",
        "windows",
    ],
    visibility = ["//visibility:public"],
)

