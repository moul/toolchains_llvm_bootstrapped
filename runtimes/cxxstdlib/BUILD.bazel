package(default_visibility = ["//visibility:public"])

config_setting(
    name = "libcxx_linux",
    constraint_values = [
        "//constraints/cxxstdlib:libcxx",
        "@platforms//os:linux",
    ],
)

config_setting(
    name = "libcxx_windows",
    constraint_values = [
        "//constraints/cxxstdlib:libcxx",
        "@platforms//os:windows",
    ],
)

config_setting(
    name = "libstdcxx_linux",
    constraint_values = [
        "//constraints/cxxstdlib:libstdcxx",
        "@platforms//os:linux",
    ],
)

# Recognize the Windows selection only to fail at the cxxstdlib routing
# boundary. The MinGW source/header entries in the libstdc++ port are audit
# parity with GCC, not supported runtime wiring yet.
config_setting(
    name = "libstdcxx_windows",
    constraint_values = [
        "//constraints/cxxstdlib:libstdcxx",
        "@platforms//os:windows",
    ],
)

alias(
    name = "headers_include_search_directory",
    actual = select({
        ":libstdcxx_linux": "//runtimes/libstdcxx:headers_include_search_directory",
        ":libstdcxx_windows": ":libstdcxx_windows_unsupported",
        "//conditions:default": "@llvm-project//libcxx:libcxx_headers_include_search_directory",
    }),
)

alias(
    name = "abi_headers_include_search_directory",
    actual = select({
        ":libstdcxx_linux": "//runtimes/libstdcxx:abi_headers_include_search_directory",
        ":libstdcxx_windows": ":libstdcxx_windows_unsupported",
        "//conditions:default": "@llvm-project//libcxxabi:libcxxabi_headers_include_search_directory",
    }),
)

alias(
    name = "library_search_directory",
    actual = select({
        ":libstdcxx_linux": "//runtimes/libstdcxx:libstdcxx_library_search_directory",
        ":libstdcxx_windows": ":libstdcxx_windows_unsupported",
        "//conditions:default": "//runtimes/libcxx:libcxx_library_search_directory",
    }),
)

alias(
    name = "libstdcxx_dynamic_runtime_lib",
    actual = "//runtimes/libstdcxx:libstdcxx_shared_soname",
)

genrule(
    name = "libstdcxx_static_runtime_lib",
    outs = ["unsupported/libstdc++.a"],
    cmd = "echo 'libstdc++ is only supported as a dynamic C++ runtime; static libstdc++ is intentionally unsupported.' >&2; exit 1",
)

genrule(
    name = "libstdcxx_windows_unsupported",
    outs = ["unsupported/windows-libstdcxx"],
    # TODO(corentin): replace this with MinGW libstdc++ DLL/import-library
    # wiring once Windows libstdc++ support is intentionally added.
    cmd = "echo 'libstdc++ is currently supported only for Linux targets; Windows/MinGW libstdc++ is intentionally unsupported.' >&2; exit 1",
)

filegroup(
    name = "static_runtime_lib",
    srcs = select({
        ":libstdcxx_linux": [":libstdcxx_static_runtime_lib"],
        ":libstdcxx_windows": [":libstdcxx_windows_unsupported"],
        ":libcxx_linux": [
            "@llvm-project//libcxx:libcxx.static",
            "@llvm-project//libcxxabi:libcxxabi.static",
            "@llvm-project//libunwind:libunwind.static",
        ],
        ":libcxx_windows": [
            "@llvm-project//libcxx:libcxx.static",
            "@llvm-project//libcxxabi:libcxxabi.static",
            "@llvm-project//libunwind:libunwind.static",
        ],
        "//conditions:default": [],
    }),
)

filegroup(
    name = "dynamic_runtime_lib",
    srcs = select({
        ":libstdcxx_linux": [
            ":libstdcxx_dynamic_runtime_lib",
            "//runtimes/libunwind:libunwind.shared",
        ],
        ":libstdcxx_windows": [":libstdcxx_windows_unsupported"],
        ":libcxx_linux": [
            "@llvm-project//libcxx:libcxx.shared",
            "@llvm-project//libcxxabi:libcxxabi.shared",
            "@llvm-project//libunwind:libunwind.shared",
        ],
        # TODO(zbarsky): windows?
        "//conditions:default": [],
    }),
)
