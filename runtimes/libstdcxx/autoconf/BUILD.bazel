load("@bazel_lib//:bzl_library.bzl", "bzl_library")

package(default_visibility = [
    "//runtimes/libstdcxx:__pkg__",
    "//runtimes/libstdcxx/tests:__pkg__",
])

exports_files(
    [
        "autoconf_config.bzl",
        "autoconf_hdr.bzl",
        "cc_configure_probe.bzl",
        "checks.bzl",
        "providers.bzl",
    ],
    visibility = [
        "//runtimes/libstdcxx:__pkg__",
        "//runtimes/libstdcxx/tests:__pkg__",
    ],
)

bzl_library(
    name = "autoconf_config",
    srcs = ["autoconf_config.bzl"],
    deps = [
        ":cc_configure_probe",
        ":providers",
        "@llvm//toolchain/runtimes:with_cfg_runtimes_common",
        "@with_cfg.bzl//:with_cfg",
    ],
)

bzl_library(
    name = "autoconf_hdr",
    srcs = ["autoconf_hdr.bzl"],
    deps = [":providers"],
)

bzl_library(
    name = "cc_configure_probe",
    srcs = ["cc_configure_probe.bzl"],
    deps = [
        "@rules_cc//cc:action_names_bzl",
        "@rules_cc//cc:find_cc_toolchain_bzl",
        "@rules_cc//cc/common",
    ],
)

bzl_library(
    name = "checks",
    srcs = ["checks.bzl"],
)

bzl_library(
    name = "providers",
    srcs = ["providers.bzl"],
)
