load("@bazel_lib//lib:transitions.bzl", "platform_transition_filegroup")
load("@bazel_skylib//rules:write_file.bzl", "write_file")
load("@rules_cc//cc:cc_binary.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load("//3rd_party/gcc:version.bzl", "GCC_VERSIONS", "gcc_repository_label", "gcc_target_suffix", "libstdcxx_constraint_value")
load("//constraints/libc:libc_versions.bzl", "default_libc")

package(default_visibility = ["//visibility:public"])

sh_test(
    name = "shared_elf_test",
    srcs = ["libstdcxx_shared_elf_test.sh"],
    data = [
        "//runtimes/libstdcxx:libstdcxx.shared",
        "//runtimes/libstdcxx:libstdcxx_shared_linker_name",
        "//runtimes/libstdcxx:libstdcxx_shared_soname",
        "@llvm//tools:llvm-readelf",
    ],
    env = {
        "LIBSTDCXX_SHARED": "$(rootpath //runtimes/libstdcxx:libstdcxx.shared)",
        "LIBSTDCXX_SHARED_LINKER_NAME": "$(rootpath //runtimes/libstdcxx:libstdcxx_shared_linker_name)",
        "LIBSTDCXX_SHARED_SONAME": "$(rootpath //runtimes/libstdcxx:libstdcxx_shared_soname)",
        "READELF": "$(rootpath @llvm//tools:llvm-readelf)",
    },
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

write_file(
    name = "libstdcxx_link_smoke_src",
    out = "libstdcxx_link_smoke.cc",
    content = [
        "#include <stdexcept>",
        "#include <string>",
        "#include <vector>",
        "",
        "int main() {",
        "  std::vector<std::string> values;",
        "  values.emplace_back(\"libstdc++\");",
        "  if (values.front().size() != 9) throw std::runtime_error(\"bad string\");",
        "  return 0;",
        "}",
    ],
)

cc_binary(
    name = "toolchain_dynamic_link_smoke",
    srcs = [":libstdcxx_link_smoke_src"],
    linkstatic = False,
    target_compatible_with = select({
        "//constraints/cxxstdlib:libstdcxx": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }) + [
        "@platforms//os:linux",
    ],
)

[
    platform(
        name = "linux_{}_{}".format(
            arch,
            libstdcxx_constraint_value(version),
        ),
        constraint_values = [
            "@platforms//cpu:{}".format(arch),
            "@platforms//os:linux",
            "//constraints/libc:{}".format(default_libc("linux", arch)),
            "//constraints/cxxstdlib:{}".format(libstdcxx_constraint_value(version)),
        ],
    )
    for arch in [
        "x86_64",
        "aarch64",
    ]
    for version in GCC_VERSIONS
]

[
    platform_transition_filegroup(
        name = "toolchain_dynamic_link_smoke_linux_{}_{}".format(
            arch,
            gcc_target_suffix(version),
        ),
        srcs = [":toolchain_dynamic_link_smoke"],
        target_platform = ":linux_{}_{}".format(
            arch,
            libstdcxx_constraint_value(version),
        ),
    )
    for arch in [
        "x86_64",
        "aarch64",
    ]
    for version in GCC_VERSIONS
]

[
    filegroup(
        name = "toolchain_dynamic_link_smoke_linux_{}_all_versions".format(arch),
        srcs = [
            ":toolchain_dynamic_link_smoke_linux_{}_{}".format(
                arch,
                gcc_target_suffix(version),
            )
            for version in GCC_VERSIONS
        ],
    )
    for arch in [
        "x86_64",
        "aarch64",
    ]
]

filegroup(
    name = "toolchain_dynamic_link_smoke_linux_all_versions",
    srcs = [
        ":toolchain_dynamic_link_smoke_linux_aarch64_all_versions",
        ":toolchain_dynamic_link_smoke_linux_x86_64_all_versions",
    ],
)

[
    platform_transition_filegroup(
        name = "libstdcxx_cxx26_compile_linux_{}_{}".format(
            arch,
            gcc_target_suffix(version),
        ),
        srcs = [gcc_repository_label(version, "libstdcxx_cxx26")],
        target_platform = ":linux_{}_{}".format(
            arch,
            libstdcxx_constraint_value(version),
        ),
    )
    for arch in [
        "x86_64",
        "aarch64",
    ]
    for version in GCC_VERSIONS
]

[
    filegroup(
        name = "libstdcxx_cxx26_compile_linux_{}_all_versions".format(arch),
        srcs = [
            ":libstdcxx_cxx26_compile_linux_{}_{}".format(
                arch,
                gcc_target_suffix(version),
            )
            for version in GCC_VERSIONS
        ],
    )
    for arch in [
        "x86_64",
        "aarch64",
    ]
]

filegroup(
    name = "libstdcxx_cxx26_compile_linux_all_versions",
    srcs = [
        ":libstdcxx_cxx26_compile_linux_aarch64_all_versions",
        ":libstdcxx_cxx26_compile_linux_x86_64_all_versions",
    ],
)
