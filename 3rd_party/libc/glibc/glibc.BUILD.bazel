load("@bazel_skylib//lib:selects.bzl", "selects")
load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@llvm//3rd_party/libc/glibc:helpers.bzl", "glibc_includes")
load("@llvm//toolchain/args:llvm_target_triple.bzl", "LLVM_TARGET_TRIPLE")
load("@llvm//toolchain/runtimes:cc_runtime_library.bzl", "cc_runtime_stage0_library")
load("@llvm//toolchain/runtimes:cc_runtime_static_library.bzl", "cc_runtime_stage0_static_library")
load("@llvm//toolchain/runtimes:cc_stage0_object.bzl", "cc_stage0_object")

alias(
    name = "gnu_libc_headers",
    actual = "@glibc//:gnu_libc_headers",
)

alias(
    name = "kernel_headers",
    actual = "@kernel_headers//:kernel_headers",
)

HDRS = glob(
    [
        "bits/**/*.h",
        "csu/**",
        "debug/**/*.h",
        "elf/**/*.h",
        "include/**/*.h",
        "io/**/*.h",
        "locale/**/*.h",
        "misc/**/*.h",
        "posix/**/*.h",
        "signal/**/*.h",
        "stdlib/**/*.h",
        "string/**/*.h",
        "sysdeps/**/*.h",
        "time/**/*.h",
    ],
    exclude = [
        # These are template stubs with unconditional #error directives.
        # The real versions come from arch-specific sysdeps/ or system headers.
        "bits/endian.h",
        "bits/link.h",
        "bits/wordsize.h",
    ],
)

cc_runtime_stage0_library(
    name = "glibc_init",
    srcs = ["csu/init.c"],
    copts = [
        # Normally, we would pass -nostdinc, but since we pass -nostdlibinc
        # from the stage0 toolchain args regarless, having them both cause a
        # warning about -nostdlibinc being ignored, so we duplicate the
        # -nostdlibinc and add -nobuiltininc to avoid the warning.
        #
        # -nostdinc = -nostdlibinc -nobuiltininc
        "-nostdlibinc",
        "-nobuiltininc",
        "-fno-addrsig",
    ],
    visibility = ["//visibility:public"],
)

cc_runtime_stage0_library(
    name = "glibc_abi_note",
    srcs = [
        "@llvm//3rd_party/libc/glibc/csu:abi-note-2.31.S",
    ],
    hdrs = HDRS,
    copts = [
        # Normally, we would pass -nostdinc, but since we pass -nostdlibinc
        # from the stage0 toolchain args regarless, having them both cause a
        # warning about -nostdlibinc being ignored, so we duplicate the
        # -nostdlibinc and add -nobuiltininc to avoid the warning.
        #
        # -nostdinc = -nostdlibinc -nobuiltininc
        "-nostdlibinc",
        "-nobuiltininc",
        "-Wa,--noexecstack",
    ],
    includes = [
        "csu",
    ] + select({
        "@platforms//cpu:x86_64": glibc_includes("x86_64"),
        "@platforms//cpu:aarch64": glibc_includes("aarch64"),
        "@platforms//cpu:riscv64": glibc_includes("riscv64"),
        "@platforms//cpu:s390x": glibc_includes("s390x"),
    }),
    local_defines = [
        "_LIBC_REENTRANT",
        "MODULE_NAME=libc",
        "TOP_NAMESPACE=glibc",
        "ASSEMBLER",
    ],
    visibility = ["//visibility:public"],
)

cc_runtime_stage0_library(
    name = "glibc_start",
    srcs = select(
        {
            "@platforms//cpu:x86_64": ["sysdeps/x86_64/start.S"],
            "@platforms//cpu:aarch64": ["sysdeps/aarch64/start.S"],
            "@platforms//cpu:riscv64": ["sysdeps/riscv/start.S"],
            "@platforms//cpu:s390x": ["sysdeps/s390/s390-64/start.S"],
        },
        no_match_error = "Unsupported platform",
    ),
    hdrs = HDRS,
    additional_compiler_inputs = [
        "include/libc-modules.h",
        "include/libc-symbols.h",
    ],
    copts = [
        # Normally, we would pass -nostdinc, but since we pass -nostdlibinc
        # from the stage0 toolchain args regarless, having them both cause a
        # warning about -nostdlibinc being ignored, so we duplicate the
        # -nostdlibinc and add -nobuiltininc to avoid the warning.
        #
        # -nostdinc = -nostdlibinc -nobuiltininc
        "-nostdlibinc",
        "-nobuiltininc",
        "-Wno-nonportable-include-path",
        "-Wa,--noexecstack",
        "-include",
        "$(location include/libc-modules.h)",
        "-DMODULE_NAME=libc",
        "-include",
        "$(location include/libc-symbols.h)",
    ],
    implementation_deps = [
        ":gnu_libc_headers",
        ":kernel_headers",
    ],
    includes = select({
        "@platforms//cpu:x86_64": glibc_includes("x86_64"),
        "@platforms//cpu:aarch64": glibc_includes("aarch64"),
        "@platforms//cpu:riscv64": glibc_includes("riscv64"),
        "@platforms//cpu:s390x": glibc_includes("s390x"),
    }),
    local_defines = [
        "_LIBC_REENTRANT",
        "MODULE_NAME=libc",
        "PIC",
        "SHARED",
        "TOP_NAMESPACE=glibc",
        "ASSEMBLER",
    ],
    visibility = ["//visibility:public"],
)

cc_runtime_stage0_library(
    name = "glibc_Scrt1",
    visibility = ["//visibility:public"],
    deps = [
        ":glibc_abi_note",
        ":glibc_init",
        ":glibc_start",
    ],
)

cc_stage0_object(
    name = "glibc_Scrt1.object",
    srcs = [
        ":glibc_abi_note",
        ":glibc_init",
        ":glibc_start",
    ],
    out = "Scrt1.o",
    copts = [
        "-target",
    ] + LLVM_TARGET_TRIPLE,
    visibility = ["//visibility:public"],
)

#TODO(cerisier): start.o should be compiled without -DSHARED here.
#TODO(cerisier): Also find out why this is compiled with -DPIC by the glibc
# even tho it's for -no-pie...
copy_file(
    name = "glibc_crt1.object",
    src = "Scrt1.o",
    out = "crt1.o",
    visibility = ["//visibility:public"],
)

