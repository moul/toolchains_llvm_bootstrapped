# Local autoconf-style config header renderer.
#
# This rule only renders ordered results from autoconf_config. It does not know
# how checks are executed, which keeps generated-header policy separate from
# compile/link probing.

load(":providers.bzl", "AutoconfConfigInfo")

def _write_config_output(ctx, config_h, results):
    arguments = [
        config_h.path,
        ctx.attr.include_guard,
        ctx.attr.header_comment,
    ]
    inputs = []

    result_ops = []
    for result in results:
        result_path = ""
        if result.result:
            result_path = result.result.path
            inputs.append(result.result)
        result_ops.append([
            result.check.name,
            result.kind,
            getattr(result.check, "value", ""),
            result_path,
            ",".join(getattr(result.check, "defines_on_success", [])),
        ])

    ops_file = ctx.actions.declare_file("result_ops")
    ctx.actions.write(ops_file, "\n".join([":".join(op) for op in result_ops]))
    inputs.append(ops_file)
    arguments.append(ops_file.path)

    ctx.actions.run_shell(
        inputs = inputs,
        outputs = [config_h],
        arguments = arguments,
        command = """set -eu
config_h="$1"
include_guard="$2"
header_comment="$3"
args="$4"

{
    printf '/* %s */\\n' "$header_comment"
    echo "#ifndef $include_guard"
    echo "#define $include_guard 1"
    while IFS=':' read -r name kind value result_file defines_on_success; do
        [[ -z "$name" || "$name" == \\#* ]] && continue
        if [ "$kind" = "define" ]; then
            old_ifs="$IFS"
            IFS=","
            for define_name in $defines_on_success; do
                echo "#define $define_name $value"
            done
            IFS="$old_ifs"
        elif [ "$kind" = "string_define" ]; then
            echo "#define $name \\"$value\\""
        elif [ "$kind" = "undef" ]; then
            echo "/* #undef $name */"
        else
            result="$(cat "$result_file")"
            old_ifs="$IFS"
            IFS=","
            if [ "$result" = true ]; then
                for define_name in $defines_on_success; do
                    echo "#define $define_name 1"
                done
            else
                for define_name in $defines_on_success; do
                    echo "/* #undef $define_name */"
                done
            fi
            IFS="$old_ifs"
        fi
    done < "$args"
    echo "#endif"
} > "$config_h"
""",
        mnemonic = "AutoconfHdr",
    )

def _autoconf_hdr_impl(ctx):
    _write_config_output(ctx, ctx.outputs.out, ctx.attr.dep[AutoconfConfigInfo].results)
    return [
        DefaultInfo(files = depset([ctx.outputs.out])),
        OutputGroupInfo(config_h = depset([ctx.outputs.out])),
    ]

autoconf_hdr = rule(
    implementation = _autoconf_hdr_impl,
    attrs = {
        "dep": attr.label(
            mandatory = True,
            providers = [AutoconfConfigInfo],
        ),
        "header_comment": attr.string(default = "Generated by autoconf_hdr."),
        "include_guard": attr.string(mandatory = True),
        "out": attr.output(mandatory = True),
    },
)
