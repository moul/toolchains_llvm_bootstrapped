+++ b/clang-tools-extra/clangd/tool/Opts.td
@@ -0,0 +1,376 @@
+include "llvm/Option/OptParser.td"
+
+def compile_commands_group : OptionGroup<"compile-commands">,
+                             HelpText<"clangd compilation flags options">;
+def features_group : OptionGroup<"features">,
+                     HelpText<"clangd feature options">;
+def protocol_group : OptionGroup<"protocol">,
+                     HelpText<"clangd protocol and logging options">;
+def misc_group : OptionGroup<"misc">, HelpText<"clangd miscellaneous options">;
+def check_group : OptionGroup<"check">,
+                  HelpText<"clangd check-mode options">,
+                  Flags<[HelpHidden]>;
