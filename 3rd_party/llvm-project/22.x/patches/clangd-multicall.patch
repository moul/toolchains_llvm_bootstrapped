+
+namespace clang {
+namespace clangd {
+
+enum CompileArgsFromFlag { LSPCompileArgs, FilesystemCompileArgs };
+enum CompletionStyleFlag { Detailed, Bundled };
+enum PCHStorageFlag { Disk, Memory };
+
+struct CommandLineOptions {
+  CompileArgsFromFlag CompileArgsFrom = FilesystemCompileArgs;
+  std::string CompileCommandsDir;
+  std::string ResourceDir;
+  std::vector<std::string> QueryDriverGlobs;
+
+  bool AllScopesCompletion = true;
+  bool AllScopesCompletionSpecified = false;
+  bool ShowOrigins = CodeCompleteOptions().ShowOrigins;
+  bool EnableBackgroundIndex = true;
+  bool EnableBackgroundIndexSpecified = false;
+  llvm::ThreadPriority BackgroundIndexPriority = llvm::ThreadPriority::Low;
+  bool EnableClangTidy = true;
+  CodeCompleteOptions::CodeCompletionParse CodeCompletionParse =
+      CodeCompleteOptions().RunParser;
+  CodeCompleteOptions::CodeCompletionRankingModel RankingModel =
+      CodeCompleteOptions().RankingModel;
+  CompletionStyleFlag CompletionStyle = Detailed;
+  bool CompletionStyleSpecified = false;
+  std::string FallbackStyle;
+  bool FallbackStyleSpecified = false;
+  std::string FunctionArgPlaceholders = "-1";
+  Config::HeaderInsertionPolicy HeaderInsertion =
+      CodeCompleteOptions().InsertIncludes;
+  bool HeaderInsertionSpecified = false;
+  bool ImportInsertions = CodeCompleteOptions().ImportInsertions;
+  bool HeaderInsertionDecorators = true;
+  bool HiddenFeatures = false;
+  bool IncludeIneligibleResults =
+      CodeCompleteOptions().IncludeIneligibleResults;
+  int LimitResults = 100;
+  int ReferencesLimit = 1000;
+  int RenameFileLimit = 50;
+  std::vector<std::string> TweakList;
+  bool TweaksSpecified = false;
+  bool StrongWorkspaceMode = false;
+  bool ExperimentalModulesSupport = false;
+
+  unsigned WorkerThreadsCount;
+  bool WorkerThreadsCountSpecified = false;
+  std::string IndexFile;
+  bool Test = false;
+  bool CrashPragmas = false;
+  bool CrashPragmasSpecified = false;
+  bool CheckSpecified = false;
+  std::string CheckFile;
+  PCHStorageFlag PCHStorage = Disk;
+  bool Sync = false;
+  bool SyncSpecified = false;
+  bool EnableConfig = true;
+  bool EnableConfigSpecified = false;
+  bool UseDirtyHeaders;
+  bool PreambleParseForwardingFunctions;
+  bool EnableMallocTrim = true;
+
+  JSONStreamStyle InputStyle = JSONStreamStyle::Standard;
+  bool EnableTestScheme = false;
+  std::string PathMappingsArg;
+  std::string InputMirrorFile;
+  Logger::Level LogLevel = Logger::Info;
+  OffsetEncoding ForceOffsetEncoding = OffsetEncoding::UnsupportedEncoding;
+  bool PrettyPrint = false;
+
+  std::string RemoteIndexAddress;
+  std::string ProjectRoot;
+  ClangdCheckOptions CheckOpts;
+
+  CommandLineOptions();
+};
+
+enum class ParseResult { Continue, ExitSuccess, Error };
+
+ParseResult parseCommandLine(int argc, char **argv, CommandLineOptions &Opts);
+llvm::StringRef clangdOverview();
+const char *clangdFlagsEnvVar();
+std::function<void()> getMemoryCleanupFunction(bool EnableMallocTrim);
+
+} // namespace clangd
+} // namespace clang
