index 000000000000..0fda8b7942b8
--- /dev/null
+++ b/clang-tools-extra/clangd/tool/Options.cpp
@@ -0,0 +1,450 @@
+//===--- Options.cpp - clangd command-line options --------------*- C++ -*-===//
+//
+// Part of the LLVM Project, under the Apache License v2.0 with LLVM Exceptions.
+// See https://llvm.org/LICENSE.txt for license information.
+// SPDX-License-Identifier: Apache-2.0 WITH LLVM-exception
+//
+//===----------------------------------------------------------------------===//
+
+#include "Options.h"
+#include "ClangdServer.h"
+#include "Feature.h"
+#include "Preamble.h"
+#include "clang/Format/Format.h"
+#include "llvm/ADT/SmallVector.h"
+#include "llvm/ADT/StringExtras.h"
+#include "llvm/ADT/StringSwitch.h"
+#include "llvm/ADT/Twine.h"
+#include "llvm/Option/Arg.h"
+#include "llvm/Option/ArgList.h"
+#include "llvm/Option/OptTable.h"
+#include "llvm/Option/Option.h"
+#include "llvm/Support/Allocator.h"
+#include "llvm/Support/StringSaver.h"
+#include "llvm/Support/raw_ostream.h"
+#include <optional>
+
+#ifdef __GLIBC__
+#include <malloc.h>
+#endif
+
+namespace clang {
+namespace clangd {
+namespace {
+
+using namespace llvm;
+using namespace llvm::opt;
+
+#if defined(__GLIBC__) && CLANGD_MALLOC_TRIM
+static constexpr unsigned MallocTrimVis = 1U << 8;
+#else
+static constexpr unsigned MallocTrimVis = 0;
+#endif
+
+#if CLANGD_ENABLE_REMOTE
+static constexpr unsigned RemoteVis = 1U << 9;
+#else
+static constexpr unsigned RemoteVis = 0;
+#endif
+
+enum ID {
+  OPT_INVALID = 0,
+#define OPTION(...) LLVM_MAKE_OPT_ID(__VA_ARGS__),
+#include "Opts.inc"
+#undef OPTION
+};
+
+#define OPTTABLE_STR_TABLE_CODE
+#include "Opts.inc"
+#undef OPTTABLE_STR_TABLE_CODE
+
+#define OPTTABLE_PREFIXES_TABLE_CODE
+#include "Opts.inc"
+#undef OPTTABLE_PREFIXES_TABLE_CODE
+
+static constexpr opt::OptTable::Info InfoTable[] = {
+#define OPTION(...) LLVM_CONSTRUCT_OPT_INFO(__VA_ARGS__),
+#include "Opts.inc"
+#undef OPTION
+};
+
+class ClangdOptTable : public opt::GenericOptTable {
+public:
+  ClangdOptTable()
+      : opt::GenericOptTable(OptionStrTable, OptionPrefixesTable, InfoTable) {}
+};
+
+static bool parseBoolArg(const opt::Arg *A, unsigned ValueID, bool &Value) {
+  if (!A->getOption().matches(ValueID)) {
+    Value = true;
+    return true;
+  }
+  std::optional<bool> Parsed = StringSwitch<std::optional<bool>>(A->getValue())
+                                   .CaseLower("true", true)
+                                   .Case("1", true)
+                                   .CaseLower("false", false)
+                                   .Case("0", false)
+                                   .Default(std::nullopt);
+  if (Parsed) {
+    Value = *Parsed;
+    return true;
+  }
+  errs() << "clangd: invalid value '" << A->getValue() << "' for option '"
+         << A->getSpelling() << "'\n";
+  return false;
+}
+
+static bool parseBoolArg(const opt::InputArgList &Args, unsigned FlagID,
+                         unsigned ValueID, bool Default, bool &Value,
+                         bool *Specified = nullptr) {
+  const opt::Arg *A = Args.getLastArg(FlagID, ValueID);
+  if (Specified)
+    *Specified = A != nullptr;
+  Value = Default;
+  return !A || parseBoolArg(A, ValueID, Value);
+}
+
+template <typename T>
+static bool parseIntArg(const opt::InputArgList &Args, unsigned ID, T &Value,
+                        bool *Specified = nullptr) {
+  const opt::Arg *A = Args.getLastArg(ID);
+  if (Specified)
+    *Specified = A != nullptr;
+  if (!A)
+    return true;
+  StringRef Text = A->getValue();
+  if (llvm::to_integer(Text, Value, 0))
+    return true;
+  errs() << "clangd: invalid integer value '" << Text << "' for option '"
+         << A->getSpelling() << "'\n";
+  return false;
+}
+
+static ParseResult invalidValue(const opt::Arg *A) {
+  errs() << "clangd: invalid value '" << A->getValue() << "' for option '"
+         << A->getSpelling() << "'\n";
+  return ParseResult::Error;
+}
+
+static void appendCommaSeparated(StringRef Value,
+                                 std::vector<std::string> &Result) {
+  SmallVector<StringRef, 8> Values;
+  Value.split(Values, ',', /*MaxSplit=*/-1, /*KeepEmpty=*/false);
+  for (StringRef V : Values)
+    Result.push_back(V.str());
+}
+
+} // namespace
+
+CommandLineOptions::CommandLineOptions()
+    : FallbackStyle(clang::format::DefaultFallbackStyle),
+      WorkerThreadsCount(getDefaultAsyncThreadsCount()),
+      UseDirtyHeaders(ClangdServer::Options().UseDirtyHeaders),
+      PreambleParseForwardingFunctions(
+          ParseOptions().PreambleParseForwardingFunctions) {}
+
+llvm::StringRef clangdOverview() {
+  return R"(clangd is a language server that provides IDE-like features to editors.
+
+It should be used via an editor plugin rather than invoked directly. For more information, see:
+	https://clangd.llvm.org/
+	https://microsoft.github.io/language-server-protocol/
+
+clangd accepts flags on the commandline, and in the CLANGD_FLAGS environment variable.
+)";
+}
+
+const char *clangdFlagsEnvVar() { return "CLANGD_FLAGS"; }
+
+ParseResult parseCommandLine(int argc, char **argv, CommandLineOptions &Opts) {
+  BumpPtrAllocator Allocator;
+  StringSaver Saver(Allocator);
+  ClangdOptTable Tbl;
+  Tbl.setInitialOptionsFromEnvironment(clangdFlagsEnvVar());
+  bool HasError = false;
+  opt::InputArgList Args =
+      Tbl.parseArgs(argc, argv, OPT_UNKNOWN, Saver, [&](StringRef Message) {
+        errs() << argv[0] << ": " << Message << '\n';
+        HasError = true;
+      });
+  for (const opt::Arg *A : Args.filtered(OPT_INPUT)) {
+    errs() << argv[0] << ": unknown argument '" << A->getValue() << "'\n";
+    HasError = true;
+  }
+  if (HasError)
+    return ParseResult::Error;
+
+  if (Args.hasArg(OPT_help, OPT_help_hidden)) {
+    unsigned VisibilityMask = DefaultVis | MallocTrimVis | RemoteVis;
+    Tbl.printHelp(outs(), (Twine(argv[0]) + " [options]").str().c_str(),
+                  clangdOverview().str().c_str(), Args.hasArg(OPT_help_hidden),
+                  /*ShowAllAliases=*/false,
+                  llvm::opt::Visibility(VisibilityMask),
+                  /*SubCommand=*/StringRef());
+    return ParseResult::ExitSuccess;
+  }
+
+  if (Args.hasArg(OPT_version)) {
+    outs() << versionString() << "\n"
+           << "Features: " << featureString() << "\n"
+           << "Platform: " << platformString() << "\n";
+    return ParseResult::ExitSuccess;
+  }
+
+  for (const opt::Arg *A : Args) {
+    Option Group = A->getOption().getGroup();
+    if (Group.isValid() && Group.matches(OPT_retired_group)) {
+      StringRef Name = A->getOption().getName();
+      Name.consume_back("=");
+      errs() << "The flag `-" << Name << "` is obsolete and ignored.\n";
+    }
+  }
+
+  if (const opt::Arg *A = Args.getLastArg(OPT_compile_args_from_EQ)) {
+    std::optional<CompileArgsFromFlag> Value =
+        StringSwitch<std::optional<CompileArgsFromFlag>>(A->getValue())
+            .Case("lsp", LSPCompileArgs)
+            .Case("filesystem", FilesystemCompileArgs)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.CompileArgsFrom = *Value;
+  }
+  Opts.CompileCommandsDir =
+      Args.getLastArgValue(OPT_compile_commands_dir_EQ).str();
+  Opts.ResourceDir = Args.getLastArgValue(OPT_resource_dir_EQ).str();
+  for (const std::string &Value : Args.getAllArgValues(OPT_query_driver_EQ))
+    appendCommaSeparated(Value, Opts.QueryDriverGlobs);
+
+  bool OK = true;
+  OK &= parseBoolArg(
+      Args, OPT_all_scopes_completion, OPT_all_scopes_completion_EQ, true,
+      Opts.AllScopesCompletion, &Opts.AllScopesCompletionSpecified);
+  OK &= parseBoolArg(Args, OPT_debug_origin, OPT_debug_origin_EQ,
+                     CodeCompleteOptions().ShowOrigins, Opts.ShowOrigins);
+  OK &= parseBoolArg(Args, OPT_background_index, OPT_background_index_EQ, true,
+                     Opts.EnableBackgroundIndex,
+                     &Opts.EnableBackgroundIndexSpecified);
+  OK &= parseBoolArg(Args, OPT_clang_tidy, OPT_clang_tidy_EQ, true,
+                     Opts.EnableClangTidy);
+  OK &= parseBoolArg(Args, OPT_import_insertions, OPT_import_insertions_EQ,
+                     CodeCompleteOptions().ImportInsertions,
+                     Opts.ImportInsertions);
+  OK &= parseBoolArg(Args, OPT_header_insertion_decorators,
+                     OPT_header_insertion_decorators_EQ, true,
+                     Opts.HeaderInsertionDecorators);
+  OK &= parseBoolArg(Args, OPT_hidden_features, OPT_hidden_features_EQ, false,
+                     Opts.HiddenFeatures);
+  OK &= parseBoolArg(Args, OPT_include_ineligible_results,
+                     OPT_include_ineligible_results_EQ,
+                     CodeCompleteOptions().IncludeIneligibleResults,
+                     Opts.IncludeIneligibleResults);
+  OK &= parseBoolArg(Args, OPT_strong_workspace_mode,
+                     OPT_strong_workspace_mode_EQ, false,
+                     Opts.StrongWorkspaceMode);
+  OK &= parseBoolArg(Args, OPT_experimental_modules_support,
+                     OPT_experimental_modules_support_EQ, false,
+                     Opts.ExperimentalModulesSupport);
+  OK &= parseBoolArg(Args, OPT_lit_test, OPT_lit_test_EQ, false, Opts.Test);
+  OK &= parseBoolArg(Args, OPT_crash_pragmas, OPT_crash_pragmas_EQ, false,
+                     Opts.CrashPragmas, &Opts.CrashPragmasSpecified);
+  OK &= parseBoolArg(Args, OPT_sync, OPT_sync_EQ, false, Opts.Sync,
+                     &Opts.SyncSpecified);
+  OK &= parseBoolArg(Args, OPT_enable_config, OPT_enable_config_EQ, true,
+                     Opts.EnableConfig, &Opts.EnableConfigSpecified);
+  OK &= parseBoolArg(Args, OPT_use_dirty_headers, OPT_use_dirty_headers_EQ,
+                     ClangdServer::Options().UseDirtyHeaders,
+                     Opts.UseDirtyHeaders);
+  OK &= parseBoolArg(Args, OPT_parse_forwarding_functions,
+                     OPT_parse_forwarding_functions_EQ,
+                     ParseOptions().PreambleParseForwardingFunctions,
+                     Opts.PreambleParseForwardingFunctions);
+  OK &= parseBoolArg(Args, OPT_pretty, OPT_pretty_EQ, false, Opts.PrettyPrint);
+  OK &=
+      parseBoolArg(Args, OPT_enable_test_uri_scheme,
+                   OPT_enable_test_uri_scheme_EQ, false, Opts.EnableTestScheme);
+  OK &= parseBoolArg(Args, OPT_check_locations, OPT_check_locations_EQ, true,
+                     Opts.CheckOpts.Locations);
+  OK &= parseBoolArg(Args, OPT_check_completion, OPT_check_completion_EQ, false,
+                     Opts.CheckOpts.Completion);
+  OK &= parseBoolArg(Args, OPT_check_warnings, OPT_check_warnings_EQ, false,
+                     Opts.CheckOpts.Warnings);
+#if defined(__GLIBC__) && CLANGD_MALLOC_TRIM
+  OK &= parseBoolArg(Args, OPT_malloc_trim, OPT_malloc_trim_EQ, true,
+                     Opts.EnableMallocTrim);
+#else
+  if (Args.hasArg(OPT_malloc_trim, OPT_malloc_trim_EQ)) {
+    const opt::Arg *A = Args.getLastArg(OPT_malloc_trim, OPT_malloc_trim_EQ);
+    errs() << argv[0] << ": unknown argument '" << A->getAsString(Args)
+           << "'\n";
+    OK = false;
+  }
+#endif
+  if (!OK)
+    return ParseResult::Error;
+
+  if (const opt::Arg *A = Args.getLastArg(OPT_background_index_priority_EQ)) {
+    std::optional<llvm::ThreadPriority> Value =
+        StringSwitch<std::optional<llvm::ThreadPriority>>(A->getValue())
+            .Case("background", llvm::ThreadPriority::Background)
+            .Case("low", llvm::ThreadPriority::Low)
+            .Case("normal", llvm::ThreadPriority::Default)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.BackgroundIndexPriority = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_completion_parse_EQ)) {
+    std::optional<CodeCompleteOptions::CodeCompletionParse> Value =
+        StringSwitch<std::optional<CodeCompleteOptions::CodeCompletionParse>>(
+            A->getValue())
+            .Case("always", CodeCompleteOptions::AlwaysParse)
+            .Case("auto", CodeCompleteOptions::ParseIfReady)
+            .Case("never", CodeCompleteOptions::NeverParse)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.CodeCompletionParse = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_ranking_model_EQ)) {
+    std::optional<CodeCompleteOptions::CodeCompletionRankingModel> Value =
+        StringSwitch<
+            std::optional<CodeCompleteOptions::CodeCompletionRankingModel>>(
+            A->getValue())
+            .Case("heuristics", CodeCompleteOptions::Heuristics)
+            .Case("decision_forest", CodeCompleteOptions::DecisionForest)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.RankingModel = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_completion_style_EQ)) {
+    Opts.CompletionStyleSpecified = true;
+    std::optional<CompletionStyleFlag> Value =
+        StringSwitch<std::optional<CompletionStyleFlag>>(A->getValue())
+            .Case("detailed", Detailed)
+            .Case("bundled", Bundled)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.CompletionStyle = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_header_insertion_EQ)) {
+    Opts.HeaderInsertionSpecified = true;
+    std::optional<Config::HeaderInsertionPolicy> Value =
+        StringSwitch<std::optional<Config::HeaderInsertionPolicy>>(
+            A->getValue())
+            .Case("iwyu", Config::HeaderInsertionPolicy::IWYU)
+            .Case("never", Config::HeaderInsertionPolicy::NeverInsert)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.HeaderInsertion = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_pch_storage_EQ)) {
+    std::optional<PCHStorageFlag> Value =
+        StringSwitch<std::optional<PCHStorageFlag>>(A->getValue())
+            .Case("disk", Disk)
+            .Case("memory", Memory)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.PCHStorage = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_input_style_EQ)) {
+    std::optional<JSONStreamStyle> Value =
+        StringSwitch<std::optional<JSONStreamStyle>>(A->getValue())
+            .Case("standard", JSONStreamStyle::Standard)
+            .Case("delimited", JSONStreamStyle::Delimited)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.InputStyle = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_log_EQ)) {
+    std::optional<Logger::Level> Value =
+        StringSwitch<std::optional<Logger::Level>>(A->getValue())
+            .Case("error", Logger::Error)
+            .Case("info", Logger::Info)
+            .Case("verbose", Logger::Debug)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.LogLevel = *Value;
+  }
+  if (const opt::Arg *A = Args.getLastArg(OPT_offset_encoding_EQ)) {
+    std::optional<OffsetEncoding> Value =
+        StringSwitch<std::optional<OffsetEncoding>>(A->getValue())
+            .Case("utf-8", OffsetEncoding::UTF8)
+            .Case("utf-16", OffsetEncoding::UTF16)
+            .Case("utf-32", OffsetEncoding::UTF32)
+            .Default(std::nullopt);
+    if (!Value)
+      return invalidValue(A);
+    Opts.ForceOffsetEncoding = *Value;
+  }
+
+  if (!parseIntArg(Args, OPT_j_EQ, Opts.WorkerThreadsCount,
+                   &Opts.WorkerThreadsCountSpecified) ||
+      !parseIntArg(Args, OPT_limit_results_EQ, Opts.LimitResults) ||
+      !parseIntArg(Args, OPT_limit_references_EQ, Opts.ReferencesLimit) ||
+      !parseIntArg(Args, OPT_rename_file_limit_EQ, Opts.RenameFileLimit))
+    return ParseResult::Error;
+
+  if (const opt::Arg *A = Args.getLastArg(OPT_fallback_style_EQ)) {
+    Opts.FallbackStyle = A->getValue();
+    Opts.FallbackStyleSpecified = true;
+  }
+  Opts.FunctionArgPlaceholders =
+      Args.getLastArgValue(OPT_function_arg_placeholders_EQ, "-1").str();
+  for (const std::string &Value : Args.getAllArgValues(OPT_tweaks_EQ)) {
+    Opts.TweaksSpecified = true;
+    appendCommaSeparated(Value, Opts.TweakList);
+  }
+  Opts.IndexFile = Args.getLastArgValue(OPT_index_file_EQ).str();
+  Opts.PathMappingsArg = Args.getLastArgValue(OPT_path_mappings_EQ).str();
+  Opts.InputMirrorFile = Args.getLastArgValue(OPT_input_mirror_file_EQ).str();
+
+  Opts.CheckSpecified = Args.hasArg(OPT_check, OPT_check_EQ);
+  if (const opt::Arg *A = Args.getLastArg(OPT_check_EQ))
+    Opts.CheckFile = A->getValue();
+  if (const opt::Arg *A = Args.getLastArg(OPT_check_tidy_time_EQ)) {
+    Opts.CheckOpts.TidyTime = A->getValue();
+    Opts.CheckOpts.TidyTimeSpecified = true;
+  }
+  Opts.CheckOpts.FileLines = Args.getLastArgValue(OPT_check_lines_EQ).str();
+
+#if CLANGD_ENABLE_REMOTE
+  Opts.RemoteIndexAddress =
+      Args.getLastArgValue(OPT_remote_index_address_EQ).str();
+  Opts.ProjectRoot = Args.getLastArgValue(OPT_project_root_EQ).str();
+#else
+  if (Args.hasArg(OPT_remote_index_address_EQ, OPT_project_root_EQ)) {
+    const opt::Arg *A =
+        Args.getLastArg(OPT_remote_index_address_EQ, OPT_project_root_EQ);
+    errs() << argv[0] << ": unknown argument '" << A->getAsString(Args)
+           << "'\n";
+    return ParseResult::Error;
+  }
+#endif
+
+  return ParseResult::Continue;
+}
+
+std::function<void()> getMemoryCleanupFunction(bool EnableMallocTrim) {
+#if defined(__GLIBC__) && CLANGD_MALLOC_TRIM
+  if (!EnableMallocTrim)
+    return nullptr;
+  constexpr size_t MallocTrimPad = 20'000'000;
+  return []() {
+    if (malloc_trim(MallocTrimPad))
+      vlog("Released memory via malloc_trim");
+  };
+#else
+  (void)EnableMallocTrim;
+  return nullptr;
+#endif
+}
+
+} // namespace clangd
+} // namespace clang
