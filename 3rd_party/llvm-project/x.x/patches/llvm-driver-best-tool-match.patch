+struct ToolMatch {
+  unsigned Kind = 0;
+  size_t Length = 0;
+
+  explicit operator bool() const { return Kind != 0; }
+};
+
+static bool betterMatch(ToolMatch LHS, ToolMatch RHS) {
+  return LHS.Kind != RHS.Kind ? LHS.Kind < RHS.Kind : LHS.Length < RHS.Length;
+}
+
+static ToolMatch matchTool(StringRef ToolName, StringRef Tool) {
+  ToolMatch Match;
+
+  auto MaybeUpdate = [&](StringRef Candidate) {
+    if (Candidate.equals_insensitive(Tool)) {
+      ToolMatch Exact = {2, Tool.size()};
+      if (betterMatch(Match, Exact))
+        Match = Exact;
+      return;
+    }
+
+    auto I = Candidate.rfind_insensitive(Tool);
+    if (I != StringRef::npos &&
+        (I + Tool.size() == Candidate.size() ||
+         !llvm::isAlnum(Candidate[I + Tool.size()]))) {
+      ToolMatch Suffix = {1, Tool.size()};
+      if (betterMatch(Match, Suffix))
+        Match = Suffix;
+    }
+  };
+
+  for (StringRef Candidate : {sys::path::stem(ToolName),
+                              sys::path::filename(ToolName)})
+    MaybeUpdate(Candidate);
+
+  return Match;
+}
