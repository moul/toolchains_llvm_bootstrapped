load("@bazel_lib//lib:run_binary.bzl", "run_binary")
load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@bazel_skylib//rules:expand_template.bzl", "expand_template")
load("@llvm//toolchain/runtimes:cc_runtime_library.bzl", "cc_runtime_stage0_library")
load("@rules_python//python:defs.bzl", "py_binary")

LIBOMP_COMMON_SOURCES = [
    "runtime/src/kmp_affinity.cpp",
    "runtime/src/kmp_alloc.cpp",
    "runtime/src/kmp_atomic.cpp",
    "runtime/src/kmp_barrier.cpp",
    "runtime/src/kmp_cancel.cpp",
    "runtime/src/kmp_collapse.cpp",
    "runtime/src/kmp_csupport.cpp",
    "runtime/src/kmp_debug.cpp",
    "runtime/src/kmp_dispatch.cpp",
    "runtime/src/kmp_environment.cpp",
    "runtime/src/kmp_error.cpp",
    "runtime/src/kmp_ftn_cdecl.cpp",
    "runtime/src/kmp_ftn_extra.cpp",
    "runtime/src/kmp_global.cpp",
    "runtime/src/kmp_i18n.cpp",
    "runtime/src/kmp_io.cpp",
    "runtime/src/kmp_itt.cpp",
    "runtime/src/kmp_lock.cpp",
    "runtime/src/kmp_runtime.cpp",
    "runtime/src/kmp_sched.cpp",
    "runtime/src/kmp_settings.cpp",
    "runtime/src/kmp_str.cpp",
    "runtime/src/kmp_taskdeps.cpp",
    "runtime/src/kmp_tasking.cpp",
    "runtime/src/kmp_threadprivate.cpp",
    "runtime/src/kmp_utility.cpp",
    "runtime/src/kmp_version.cpp",
    "runtime/src/kmp_wait_release.cpp",
]

_KMP_CONFIG_H_SUBSTITUTIONS = {
    "@LIBOMP_LIB_FILE@": "libomp.a",
    "@LIBOMP_VERSION_MAJOR@": "5",
    "@LIBOMP_VERSION_MINOR@": "0",
} | {
    "#cmakedefine01 %s" % symbol: "#ifndef %s\n#define %s 0\n#endif" % (symbol, symbol)
    for symbol in [
        "DEBUG_BUILD",
        "RELWITHDEBINFO_BUILD",
        "LIBOMP_USE_ITT_NOTIFY",
        "LIBOMP_USE_VERSION_SYMBOLS",
        "LIBOMP_HAVE_WEAK_ATTRIBUTE",
        "LIBOMP_HAVE_PSAPI",
        "LIBOMP_STATS",
        "LIBOMP_HAVE_X86INTRIN_H",
        "LIBOMP_HAVE___BUILTIN_READCYCLECOUNTER",
        "LIBOMP_HAVE___RDTSC",
        "LIBOMP_USE_DEBUGGER",
        "LIBOMP_OMPT_DEBUG",
        "LIBOMP_OMPT_SUPPORT",
        "LIBOMP_OMPD_SUPPORT",
        "LIBOMP_OMPX_TASKGRAPH",
        "LIBOMP_PROFILING_SUPPORT",
        "LIBOMP_OMPT_OPTIONAL",
        "LIBOMP_USE_ADAPTIVE_LOCKS",
        "LIBOMP_USE_INTERNODE_ALIGNMENT",
        "LIBOMP_ENABLE_ASSERTIONS",
        "LIBOMP_USE_HIER_SCHED",
        "STUBS_LIBRARY",
        "LIBOMP_USE_HWLOC",
        "LIBOMP_ENABLE_SHARED",
        "MSVC",
        "LIBOMP_HAVE_WAITPKG_INTRINSICS",
        "LIBOMP_HAVE_RTM_INTRINSICS",
        "LIBOMP_HAVE_IMMINTRIN_H",
        "LIBOMP_HAVE_INTRIN_H",
        "LIBOMP_HAVE_ATTRIBUTE_WAITPKG",
        "LIBOMP_HAVE_ATTRIBUTE_RTM",
        "LIBOMP_ARCH_AARCH64_A64FX",
        "LIBOMP_HAVE_XMMINTRIN_H",
        "LIBOMP_HAVE__MM_MALLOC",
        "LIBOMP_HAVE_ALIGNED_ALLOC",
        "LIBOMP_HAVE_POSIX_MEMALIGN",
        "LIBOMP_HAVE__ALIGNED_MALLOC",
        "OPENMP_ENABLE_LIBOMPTARGET",
    ]
} | select({
    "@platforms//cpu:i386": {"@LIBOMP_LEGAL_ARCH@": "IA-32"},
    "@platforms//cpu:x86_32": {"@LIBOMP_LEGAL_ARCH@": "IA-32"},
    "@platforms//cpu:x86_64": {"@LIBOMP_LEGAL_ARCH@": "Intel(R) 64"},
    "@platforms//cpu:aarch64": {"@LIBOMP_LEGAL_ARCH@": "AARCH64"},
    "@platforms//cpu:arm": {"@LIBOMP_LEGAL_ARCH@": "ARM"},
    "@platforms//cpu:riscv64": {"@LIBOMP_LEGAL_ARCH@": "RISCV64"},
    "@platforms//cpu:s390x": {"@LIBOMP_LEGAL_ARCH@": "S390X"},
    "//conditions:default": {"@LIBOMP_LEGAL_ARCH@": "UNKNOWN"},
})

expand_template(
    name = "kmp_config_h",
    out = "runtime/src/kmp_config.h",
    substitutions = _KMP_CONFIG_H_SUBSTITUTIONS,
    template = "runtime/src/kmp_config.h.cmake",
)

expand_template(
    name = "omp_h",
    out = "runtime/src/include/omp.h",
    substitutions = {
        "@LIBOMP_BUILD_DATE@": "No_Timestamp",
        "@LIBOMP_VERSION_BUILD@": "0",
        "@LIBOMP_VERSION_MAJOR@": "5",
        "@LIBOMP_VERSION_MINOR@": "0",
    },
    template = "runtime/src/include/omp.h.var",
)

copy_file(
    name = "ompx_h",
    src = "runtime/src/include/ompx.h.var",
    out = "runtime/src/include/ompx.h",
)

copy_file(
    name = "omp_tools_h",
    src = "runtime/src/include/omp-tools.h.var",
    out = "runtime/src/include/omp-tools.h",
)

py_binary(
    name = "message_converter",
    srcs = [
        "runtime/tools/libomputils.py",
        "runtime/tools/message-converter.py",
    ],
    imports = ["runtime/tools"],
    main = "runtime/tools/message-converter.py",
)

run_binary(
    name = "kmp_i18n_id_inc",
    srcs = ["runtime/src/i18n/en_US.txt"],
    outs = ["runtime/src/kmp_i18n_id.inc"],
    args = [
        "--enum=$(location runtime/src/kmp_i18n_id.inc)",
        "$(location runtime/src/i18n/en_US.txt)",
    ],
    tool = ":message_converter",
)

run_binary(
    name = "kmp_i18n_default_inc",
    srcs = ["runtime/src/i18n/en_US.txt"],
    outs = ["runtime/src/kmp_i18n_default.inc"],
    args = [
        "--default=$(location runtime/src/kmp_i18n_default.inc)",
        "$(location runtime/src/i18n/en_US.txt)",
    ],
    tool = ":message_converter",
)

filegroup(
    name = "kmp_i18n_includes",
    srcs = [
        ":kmp_i18n_default_inc",
        ":kmp_i18n_id_inc",
    ],
)

cc_runtime_stage0_library(
    name = "libomp",
    srcs = LIBOMP_COMMON_SOURCES + select({
        "@platforms//os:windows": [
            "runtime/src/z_Windows_NT-586_util.cpp",
            "runtime/src/z_Windows_NT_util.cpp",
        ],
        "//conditions:default": [
            "runtime/src/kmp_gsupport.cpp",
            "runtime/src/z_Linux_asm.S",
            "runtime/src/z_Linux_util.cpp",
        ],
    }),
    hdrs = glob(["runtime/src/**/*.h"]) + [
        ":kmp_config_h",
        ":kmp_i18n_includes",
        ":omp_h",
        ":omp_tools_h",
        ":ompx_h",
    ],
    copts = [
        "-fno-exceptions",
        "-fno-rtti",
        "-Wno-cast-qual",
        "-Wno-covered-switch-default",
        "-Wno-frame-address",
        "-Wno-int-to-void-pointer-cast",
        "-Wno-strict-aliasing",
        "-Wno-switch",
        "-Wno-uninitialized",
        "-Wno-unused-value",
    ] + select({
        "@platforms//cpu:i386": ["-mrtm"],
        "@platforms//cpu:x86_32": ["-mrtm"],
        "@platforms//cpu:x86_64": ["-mrtm"],
        "//conditions:default": [],
    }),
    implementation_deps = select({
        "@platforms//os:linux": [
            # TODO(cerisier): Provide only a subset of linux UAPI headers for musl.
            # https://github.com/cerisier/toolchains_llvm_bootstrapped/issues/146
            "@kernel_headers",
        ],
        "@platforms//os:windows": [
            "@mingw//:mingw_headers",
        ],
        "@platforms//os:macos": [],
        "//conditions:default": [],
    }) + select({
        "@llvm//platforms/config:musl": [
            "@libcxx//:headers",
            "@musl_libc//:musl_libc_headers",
        ],
        "@llvm//platforms/config:gnu": [
            # do not sort: libcxx headers must come before gnu_libc_headers
            "@libcxx//:headers",
            "@glibc//:gnu_libc_headers",
        ],
        "@platforms//os:macos": [],
        "@platforms//os:windows": [],
    }),
    includes = [
        "runtime/src",
        "runtime/src/include",
        "runtime/src/thirdparty/ittnotify",
    ],
    local_defines = select({
        "@platforms//os:windows": [
            "_CRT_SECURE_NO_WARNINGS",
            "_CRT_SECURE_NO_DEPRECATE",
            "_WINDOWS",
            "_WINNT",
            "_USRDLL",
            "LIBOMP_HAVE__ALIGNED_MALLOC=1",
        ],
        "//conditions:default": [
            "_GNU_SOURCE",
            "_REENTRANT",
            "LIBOMP_HAVE_PTHREAD_SETNAME_NP",
            "LIBOMP_HAVE_WEAK_ATTRIBUTE=1",
            "LIBOMP_HAVE_POSIX_MEMALIGN=1",
            "LIBOMP_HAVE_ALIGNED_ALLOC=1",
        ],
    }) + select({
        "@platforms//cpu:i386": [
            "LIBOMP_HAVE_IMMINTRIN_H=1",
            "LIBOMP_HAVE_RTM_INTRINSICS=1",
        ],
        "@platforms//cpu:x86_32": [
            "LIBOMP_HAVE_IMMINTRIN_H=1",
            "LIBOMP_HAVE_RTM_INTRINSICS=1",
        ],
        "@platforms//cpu:x86_64": [
            "LIBOMP_HAVE_IMMINTRIN_H=1",
            "LIBOMP_HAVE_RTM_INTRINSICS=1",
        ],
        "//conditions:default": [],
    }),
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "@platforms//os:macos": [],
        "@platforms//os:windows": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    visibility = ["//visibility:public"],
)
