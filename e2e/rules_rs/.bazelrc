import %workspace%/../../.bazelrc

# rules_rs' experimental toolchains require an explicit host platform on Linux.
# These derived platforms preserve the detected host CPU/OS and only add the
# extra libc / ABI constraints required by rules_rs toolchain resolution.
common:linux --host_platform=//:host_linux_gnu
common:windows --host_platform=//:host_windows_gnullvm

common --@rules_cc//cc/toolchains/args/archiver_flags:use_libtool_on_macos=False
common --@llvm//config:experimental_stub_libgcc_s=True
